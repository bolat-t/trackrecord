# Transport for NSW Open Data Hub — https://opendata.transport.nsw.gov.au
# 1) Register an account  2) create an "Application"  3) copy the API key below.
# Auth is sent as a header:  Authorization: apikey <key>   (NOT Bearer)
# Bronze plan quota: 60,000 calls/day, 5 requests/second.
TFNSW_API_KEY=your_tfnsw_api_key_here

# --- Phase 1+ (not needed for the Phase 0 smoke test) ---

# Free raw store for the Sydney Trains live collector (you already have an HF account).
# HF_TOKEN=
# HF_DATASET_REPO=your-username/trackrecord-raw

# Databricks workspace, for uploading raw files into a Unity Catalog Volume.
# DATABRICKS_HOST=https://<workspace>.cloud.databricks.com
# DATABRICKS_TOKEN=
